# App Configuration
# The display name of your device on the network
PEER_NAME=MyDevice

# Port configurations (Defaults are usually fine unless you have a conflict)
SERVER_PORT=4000
SOCKET_PORT=5000

# UDP configuration for automatic peer discovery
UDP_PORT=41234
UDP_BROADCAST_ADDR=255.255.255.255

# Storage directories relative to project root
DOWNLOAD_DIR=downloads
SHARED_FILES_DIR=uploads